{
  "manifest_version": 3,
  "name": "Filtro Anti-Entretenimiento YouTube",
  "version": "1.0",
  "description": "Bloquea videos y canales de entretenimiento usando la IA de Gemini.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}